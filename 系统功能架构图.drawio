        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\n&#39; 全局黑白样式优化\n!theme plain\nskinparam monochrome true\nskinparam backgroundColor #FFFFFF\nskinparam defaultFontName Microsoft YaHei\nskinparam defaultFontSize 36\nskinparam packageStyle rectangle\nskinparam shadowing false\nskinparam ArrowColor #000000\nskinparam ArrowThickness 2\nskinparam nodesep 4\nskinparam ranksep 280\nskinparam padding 4\n\nskinparam package {\n  BorderColor #000000\n  FontColor #000000\n  BackgroundColor #FFFFFF\n}\n\nskinparam rectangle {\n  BorderColor #000000\n  FontColor #000000\n  BackgroundColor #FFFFFF\n  RoundCorner 6\n}\n\nskinparam database {\n  BorderColor #000000\n  FontColor #000000\n  BackgroundColor #FFFFFF\n  StereotypeFontColor #000000\n}\n\n&#39; 整体缩放让一整行功能都能展示\nscale 0.8\n\ntop to bottom direction\n\npackage \&quot;用户层\&quot; as UserLayer {\n  rectangle \&quot;游客\&quot; as RoleGuest\n  rectangle \&quot;用户\&quot; as RoleUser\n  rectangle \&quot;店员\&quot; as RoleStaff\n  rectangle \&quot;店长\&quot; as RoleManager\n\n  rectangle \&quot;游客注册\&quot; as U_GuestRegister\n  rectangle \&quot;登录\&quot; as U_UserLogin\n  rectangle \&quot;购买商品\&quot; as U_BuyProduct\n  rectangle \&quot;订单列表\&quot; as U_OrderList\n  rectangle \&quot;AI推荐商品\&quot; as U_AiRecommendProduct\n  rectangle \&quot;个人信息管理\&quot; as U_ProfileManage\n  rectangle \&quot;登录\&quot; as U_StaffLogin\n  rectangle \&quot;考勤管理\&quot; as U_AttendanceManage\n  rectangle \&quot;店长首页数据\&quot; as U_ManagerDashboard\n  rectangle \&quot;材料管理\&quot; as U_MaterialManage\n  rectangle \&quot;订单管理\&quot; as U_OrderManage\n  rectangle \&quot;商品管理\&quot; as U_ProductManage\n  rectangle \&quot;商品分类管理\&quot; as U_ProductCategoryManage\n  rectangle \&quot;用户管理\&quot; as U_UserManage\n  rectangle \&quot;店员管理\&quot; as U_StaffManage\n\n  &#39; 角色水平对齐\n  RoleGuest -[hidden]right- RoleUser\n  RoleUser -[hidden]right- RoleStaff\n  RoleStaff -[hidden]right- RoleManager\n\n  &#39; 功能水平对齐\n  U_GuestRegister -[hidden]right- U_UserLogin\n  U_UserLogin -[hidden]right- U_BuyProduct\n  U_BuyProduct -[hidden]right- U_OrderList\n  U_OrderList -[hidden]right- U_AiRecommendProduct\n  U_AiRecommendProduct -[hidden]right- U_ProfileManage\n  U_ProfileManage -[hidden]right- U_StaffLogin\n  U_StaffLogin -[hidden]right- U_AttendanceManage\n  U_AttendanceManage -[hidden]right- U_ManagerDashboard\n  U_ManagerDashboard -[hidden]right- U_MaterialManage\n  U_MaterialManage -[hidden]right- U_OrderManage\n  U_OrderManage -[hidden]right- U_ProductManage\n  U_ProductManage -[hidden]right- U_ProductCategoryManage\n  U_ProductCategoryManage -[hidden]right- U_UserManage\n  U_UserManage -[hidden]right- U_StaffManage\n\n  &#39; 角色与功能映射\n  RoleGuest -down-&gt; U_GuestRegister\n\n  RoleUser -down-&gt; U_UserLogin\n  RoleUser -down-&gt; U_BuyProduct\n  RoleUser -down-&gt; U_OrderList\n  RoleUser -down-&gt; U_AiRecommendProduct\n  RoleUser -down-&gt; U_ProfileManage\n\n  RoleStaff -down-&gt; U_StaffLogin\n  RoleStaff -down-&gt; U_MaterialManage\n  RoleStaff -down-&gt; U_OrderManage\n\n  RoleManager -down-&gt; U_ManagerDashboard\n  RoleManager -down-&gt; U_AttendanceManage\n  RoleManager -down-&gt; U_ProductManage\n  RoleManager -down-&gt; U_ProductCategoryManage\n  RoleManager -down-&gt; U_UserManage\n  RoleManager -down-&gt; U_StaffManage\n}\n\npackage \&quot;服务层\&quot; as ServiceLayer {\n  together {\n    rectangle \&quot;认证与身份服务\&quot; as S_Auth\n    rectangle \&quot;订单交易服务\&quot; as S_Order\n    rectangle \&quot;AI推荐服务\&quot; as S_AI\n    rectangle \&quot;用户资料服务\&quot; as S_User\n    rectangle \&quot;考勤服务\&quot; as S_Attendance\n    rectangle \&quot;店长看板服务\&quot; as S_Dashboard\n    rectangle \&quot;材料服务\&quot; as S_Material\n    rectangle \&quot;商品与分类服务\&quot; as S_Product\n  }\n\n  S_Auth -[hidden]right- S_Order\n  S_Order -[hidden]right- S_AI\n  S_AI -[hidden]right- S_User\n  S_User -[hidden]right- S_Attendance\n  S_Attendance -[hidden]right- S_Dashboard\n  S_Dashboard -[hidden]right- S_Material\n  S_Material -[hidden]right- S_Product\n}\n\npackage \&quot;数据层\&quot; as DataLayer {\n  together {\n    database \&quot;用户表\&quot; as T_User\n    database \&quot;角色表\&quot; as T_Role\n    database \&quot;权限表\&quot; as T_Permission\n    database \&quot;角色权限表\&quot; as T_RolePermission\n    database \&quot;商品表\&quot; as T_Product\n    database \&quot;商品类型表\&quot; as T_ProductType\n    database \&quot;商品分类表\&quot; as T_ProductCategory\n    database \&quot;材料表\&quot; as T_Material\n    database \&quot;配方关联表\&quot; as T_CocktailRel\n    database \&quot;可配材料表\&quot; as T_ProductCfgMaterial\n    database \&quot;订单主表\&quot; as T_OrderMaster\n    database \&quot;订单项表\&quot; as T_OrderItem\n    database \&quot;定制配料表\&quot; as T_CustomMaterial\n    database \&quot;购物车表\&quot; as T_Cart\n    database \&quot;考勤表\&quot; as T_Attendance\n  }\n\n  T_User -[hidden]right- T_Role\n  T_Role -[hidden]right- T_Permission\n  T_Permission -[hidden]right- T_RolePermission\n  T_RolePermission -[hidden]right- T_Product\n  T_Product -[hidden]right- T_ProductType\n  T_ProductType -[hidden]right- T_ProductCategory\n  T_ProductCategory -[hidden]right- T_Material\n  T_Material -[hidden]right- T_CocktailRel\n  T_CocktailRel -[hidden]right- T_ProductCfgMaterial\n  T_ProductCfgMaterial -[hidden]right- T_OrderMaster\n  T_OrderMaster -[hidden]right- T_OrderItem\n  T_OrderItem -[hidden]right- T_CustomMaterial\n  T_CustomMaterial -[hidden]right- T_Cart\n  T_Cart -[hidden]right- T_Attendance\n}\n\n&#39; 用户层到服务层连线\nU_GuestRegister -down-&gt; S_Auth\nU_UserLogin -down-&gt; S_Auth\nU_BuyProduct -down-&gt; S_Order\nU_OrderList -down-&gt; S_Order\nU_AiRecommendProduct -down-&gt; S_AI\nU_ProfileManage -down-&gt; S_User\nU_StaffLogin -down-&gt; S_Auth\nU_AttendanceManage -down-&gt; S_Attendance\nU_ManagerDashboard -down-&gt; S_Dashboard\nU_MaterialManage -down-&gt; S_Material\nU_OrderManage -down-&gt; S_Order\nU_ProductManage -down-&gt; S_Product\nU_ProductCategoryManage -down-&gt; S_Product\nU_UserManage -down-&gt; S_User\nU_StaffManage -down-&gt; S_User\n\n&#39; 服务层到数据层连线\nS_Auth -down-&gt; T_User\nS_Auth -down-&gt; T_Role\nS_Auth -down-&gt; T_Permission\nS_Auth -down-&gt; T_RolePermission\n\nS_User -down-&gt; T_User\n\nS_Product -down-&gt; T_Product\nS_Product -down-&gt; T_ProductType\nS_Product -down-&gt; T_ProductCategory\n\nS_Order -down-&gt; T_OrderMaster\nS_Order -down-&gt; T_OrderItem\nS_Order -down-&gt; T_Cart\nS_Order -down-&gt; T_CustomMaterial\n\nS_AI -down-&gt; T_Material\nS_AI -down-&gt; T_CocktailRel\nS_AI -down-&gt; T_ProductCfgMaterial\n\nS_Attendance -down-&gt; T_Attendance\n\nS_Material -down-&gt; T_Material\nS_Material -down-&gt; T_CocktailRel\nS_Material -down-&gt; T_ProductCfgMaterial\n\nS_Dashboard -down-&gt; T_OrderMaster\nS_Dashboard -down-&gt; T_Attendance\n\n@enduml&quot;,&quot;format&quot;:&quot;svg&quot;}" id="S8vD2RYs2z8483lpAAT--5">
